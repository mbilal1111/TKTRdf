#!/bin/bash

set -e  # Stop on first error

echo "===================================="
echo " TKTRdf FULL REPRODUCTION PIPELINE"
echo "===================================="

# -------------------------------
# STEP 0: Environment check
# -------------------------------
echo "[0/6] Checking Python..."

python --version || { echo "❌ Python not found"; exit 1; }

# -------------------------------
# STEP 1: Install dependencies
# -------------------------------
echo "[1/6] Installing dependencies..."

pip install -r requirements.txt

# -------------------------------
# STEP 2: Convert raw Excel → RDF
# -------------------------------
echo "[2/6] Converting KG.xlsx to RDF representations..."

python scripts/preprocessing/convert_xlsx_to_all.py

# -------------------------------
# STEP 3: Generate splits
# -------------------------------
echo "[3/6] Creating dataset splits..."

python scripts/splits/create_triple_split.py
python scripts/splits/create_event_split.py

# -------------------------------
# STEP 4: Run experiments
# -------------------------------
echo "[4/6] Running KGE experiments..."

python run_experiment.py

# -------------------------------
# STEP 5: Evaluate chain prediction
# -------------------------------
echo "[5/6] Evaluating transition-chain prediction..."

python scripts/evaluation/evaluate_chain_prediction.py

# -------------------------------
# STEP 6: Completion
# -------------------------------
echo "[6/6] Pipeline complete"

echo "===================================="
echo "✅ ALL RESULTS GENERATED"
echo ""
echo "📁 Outputs available in:"
echo " - data/*/*/all.txt (generated RDF graphs)"
echo " - results/"
echo " - tables/"
echo "===================================="
